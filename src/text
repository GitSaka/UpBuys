import React, { useState } from 'react';
import axios from 'axios'; // 1. On importe axios

// Nos fausses données (Mock Data)
const INFLUENCER = {
  name: "Aïcha Digital",
  title: "Coach en Stratégie Business",
  bio: "Je transforme ton smartphone en machine à générer des revenus. 🚀",
  followers: "125K",
  avatar: "images.unsplash.com",
};

function Home() {
  const [phone, setPhone] = useState('');
  const [name, setName] = useState('');
  const [countryCode, setCountryCode] = useState("+225");
  const [isValid, setIsValid] = useState(false); 
  const [error, setError] = useState("");
  
  // 2. Nouveaux états pour la connexion
  const [step, setStep] = useState('CAPTURE'); // 'CAPTURE' ou 'VERIFICATION'
  const [otp, setOtp] = useState('');
  const [isLoading, setIsLoading] = useState(false);

  const countries = [
    { code: "+225", flag: "🇨🇮", name: "Côte d'Ivoire" },
    { code: "+221", flag: "🇸🇳", name: "Sénégal" },
    { code: "+237", flag: "🇨🇲", name: "Cameroun" },
    { code: "+241", flag: "🇬🇦", name: "Gabon" },
    { code: "+226", flag: "🇧🇫", name: "Burkina Faso" },
    { code: "+224", flag: "🇬🇳", name: "Guinée" },
    { code: "+228", flag: "🇹🇬", name: "Togo" },
    { code: "+229", flag: "🇧🇯", name: "Bénin" },
    { code: "+243", flag: "🇨🇩", name: "RDC" },
    { code: "+33", flag: "🇫🇷", name: "France (Diaspora)" },
  ];

  const validatePhoneNumber = (value) => {
    const cleanValue = value.replace(/\D/g, "");
    if (cleanValue.length > 0 && (cleanValue.length < 8 || cleanValue.length > 10)) {
      setError("Le numéro doit avoir entre 8 et 10 chiffres");
      setIsValid(false);
    } else if (cleanValue.length === 0) {
      setError("");
      setIsValid(false);
    } else {
      setError(""); 
      setIsValid(true);
    }
    setPhone(cleanValue);
  };

  // 3. LA LOGIQUE DE CONNEXION AU BACKEND

const handleAction = async (e) => {
  e.preventDefault();
  setIsLoading(true);
  setError("");

  try {
    if (step === 'CAPTURE') {
      // --- ÉTAPE 1 : ENVOI DU NUMÉRO ---
      const response = await axios.post('http://localhost:5000/api/fans/check-access', {
        phoneNumber: phone,
        countryCode: countryCode,
        name: name
      });

      if (response.data.status === "EXISTING_USER") {
        setStep('VERIFICATION'); // On affiche le champ OTP
      } else {
        // Nouveau : On redirige vers le feed
        localStorage.setItem('fanToken',response.data.token)
        window.location.href = "/saka/feed";
      }
    } else {
      // --- ÉTAPE 2 : VÉRIFICATION DU CODE ---
      const response = await axios.post('http://localhost:5000/api/fans/verify-otp', {
        phoneNumber: countryCode + phone,
        otpCode: otp // Le code tapé par l'utilisateur
      });

      if (response.data.success) {
        // ✅ Direction le Feed !
        localStorage.setItem('fanToken',response.data.token)
        window.location.href = "/saka/feed";
      }
    }
  } catch (err) {
    setError(err.response?.data?.message || "Une erreur est survenue");
  } finally {
    setIsLoading(false);
  }
};

  return (
    <div className="min-h-screen bg-gradient-to-b from-purple-50 to-white text-gray-900 font-sans pb-10 text-left">
      <header className="flex flex-col items-center pt-12 px-6">
        <div className="relative">
          <div className="w-28 h-28 rounded-full p-1 bg-gradient-to-tr from-yellow-400 via-red-500 to-purple-600">
            <img src={INFLUENCER.avatar} alt="Profil" className="w-full h-full rounded-full border-2 border-white object-cover" />
          </div>
          <div className="absolute bottom-1 right-1 bg-green-500 w-5 h-5 border-2 border-white rounded-full"></div>
        </div>
        <h1 className="mt-4 text-2xl font-black tracking-tight">{INFLUENCER.name}</h1>
        <p className="text-purple-600 font-bold text-sm uppercase tracking-widest">{INFLUENCER.title}</p>
        <p className="mt-3 text-center text-gray-600 max-w-xs leading-relaxed">{INFLUENCER.bio}</p>
      </header>

      <section className="mt-10 px-6">
        <div className="bg-white rounded-3xl p-6 shadow-2xl shadow-purple-100 border border-purple-50">
          <h2 className="text-lg font-bold text-center">
            {step === 'CAPTURE' ? 'Rejoins mon Canal Privé WhatsApp 🔐' : 'Vérification en cours 🛡️'}
          </h2>
          
                  {error && (
                        <div className="mt-3 rounded-xl bg-purple-50 px-4 py-3 text-center text-sm text-purple-700 shadow-sm">
                          <p className="font-medium">
                  Rapel capitale ✨
                </p>
                <p className="text-xs opacity-80 mt-1">
                  {error}
                </p>
              </div>
            )}
          
          
          <form onSubmit={handleAction} className="w-full mt-6 space-y-3">
            {step === 'CAPTURE' ? (
              <>
                <input 
                  type="text" placeholder="Ton Prénom" value={name}
                  onChange={(e) => setName(e.target.value)}
                  className="w-full bg-gray-50 border-none p-4 rounded-2xl focus:ring-2 focus:ring-purple-400 outline-none"
                />
                <div className='flex items-center gap-2'>
                  <select value={countryCode} onChange={(e) => setCountryCode(e.target.value)} className="bg-gray-50 border border-gray-100 rounded-2xl px-2 py-4 outline-none text-sm font-bold appearance-none">
                    {countries.map((c) => <option key={c.code} value={c.code}>{c.flag} {c.code}</option>)}
                  </select>
                  <input 
                    type="tel" placeholder="Numéro WhatsApp" value={phone}
                    onChange={(e) => validatePhoneNumber(e.target.value)}
                    className={`w-full bg-gray-50 p-4 rounded-2xl outline-none transition-all ${!isValid && phone.length > 0 ? 'border-2 border-red-300' : 'border border-gray-100'}`}
                  />
                </div>
              </>
            ) : (
              <div className="space-y-4">
                <input 
                  type="text" placeholder="Code à 4 chiffres (1234)" value={otp}
                  onChange={(e) => setOtp(e.target.value)}
                  className="w-full bg-purple-50 border-2 border-purple-200 p-4 rounded-2xl text-center text-2xl font-black tracking-[1em] outline-none"
                  maxLength="4"
                />
                <button type="button" onClick={() => setStep('CAPTURE')} className="text-[10px] uppercase font-bold text-gray-400 w-full text-center">Utiliser un autre numéro</button>
              </div>
            )}

            
            <button 
              disabled={isLoading || (step === 'CAPTURE' && !isValid)}
              className={`w-full text-white font-heavy py-4 rounded-2xl shadow-xl active:scale-95 transition-all ${isLoading ? 'bg-gray-400' : 'bg-gray-900'}`}
            >
              {isLoading ? 'TRAITEMENT...' : step === 'CAPTURE' ? 'ACCÈS VIP GRATUIT' : 'VALIDER MON ACCÈS'}
            </button>
          </form>
        </div>
      </section>

      <nav className="mt-8 px-6 space-y-4 max-w-md mx-auto">
        <button onClick={() => {
          if (!isValid) {
            setError("Inscris-toi d'abord pour accéder à la boutique VIP ! ✨");
              // On fait remonter le scroll vers le formulaire
              window.scrollTo({ top: 100, behavior: 'smooth' });
            } else {
              window.location.href = "/boutique";
            }
          }}
       className="w-full flex items-center justify-between p-4 bg-white border border-gray-100 rounded-2xl shadow-sm"><span className="flex items-center gap-3"><span>📺</span><span className="font-semibold text-gray-700 text-sm">Mes dernières vidéos</span></span><span>→</span></button>
        <button onClick={() => {
        if (!isValid) {
          setError("Inscris-toi d'abord pour accéder à la boutique VIP ! ✨");
          // On fait remonter le scroll vers le formulaire
          window.scrollTo({ top: 100, behavior: 'smooth' });
        } else {
          window.location.href = "/boutique";
        }
      }}
   className="w-full flex items-center justify-between p-4 bg-white border border-gray-100 rounded-2xl shadow-sm"><span className="flex items-center gap-3"><span>🛍️</span><span className="font-semibold text-gray-700 text-sm">Ma Boutique & Formations</span></span><span>→</span></button>
      </nav>

      <footer className="mt-12 text-center text-gray-400 text-[10px] uppercase tracking-widest">
        Propulsé par Ton Projet Souverain • 2026
      </footer>
    </div>
  );
}

